{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/index.ts"],
  "out": "docs",
  "readme": "README.md",
  "name": "@izak0s/spacebring-api",
  "includeVersion": true,
  "excludeExternals": true,
  "excludeInternal": true,
  "githubPages": true,
  "navigationLinks": {
    "npm": "https://www.npmjs.com/package/@izak0s/spacebring-api",
    "GitHub": "https://github.com/izak0s/spacebring-api"
  },
  "sort": ["source-order"],
  "exclude": ["**/generated/schema.ts", "**/node_modules/**"],
  "validation": {
    "notExported": false,
    "invalidLink": true,
    "notDocumented": false
  }
}
