{
  "name": "@izak0s/spacebring-api",
  "version": "1.0.0",
  "description": "Community-maintained TypeScript client (SDK) for the Spacebring (formerly andcards) coworking space management API",
  "license": "MIT",
  "author": "izak0s",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/izak0s/spacebring-api.git"
  },
  "homepage": "https://github.com/izak0s/spacebring-api#readme",
  "bugs": {
    "url": "https://github.com/izak0s/spacebring-api/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate:types": "openapi-typescript spec/openapi.json -o src/generated/schema.ts",
    "generate:facade": "tsx codegen/generate-facade.ts",
    "generate": "npm run generate:types && npm run generate:facade",
    "build": "tsup",
    "example": "tsx examples/basic.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:update": "vitest run --update",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run generate && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "spacebring",
    "andcards",
    "api",
    "sdk",
    "client",
    "typescript",
    "rest",
    "openapi",
    "coworking",
    "coworking-space"
  ],
  "devDependencies": {
    "@types/node": "^26.1.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  }
}
